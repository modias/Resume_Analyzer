# Copy this to .env and fill in values

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (optional — fallback used if not set)
OPENAI_API_KEY=

# RapidAPI key for JSearch (LinkedIn/Indeed job data)
# Get a free key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./internship_intelligence.db

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SMTP / Email (leave SMTP_USER empty to run in dev/print mode — code prints to console)
# For Gmail: enable "App Passwords" in your Google account and use that as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=CareerCore <your-email@gmail.com>

# LinkedIn OAuth (get credentials at https://www.linkedin.com/developers/apps)
# Create an app, add "Sign In with LinkedIn using OpenID Connect" product
# Set redirect URI to: http://localhost:8000/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
