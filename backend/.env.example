# Copy this to .env and fill in values

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (optional — fallback used if not set)
OPENAI_API_KEY=

# RapidAPI key for JSearch (LinkedIn/Indeed job data)
# Get a free key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./internship_intelligence.db

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SMTP / Email — verification codes on sign-up
# Leave SMTP_USER empty (or keep example placeholders) for dev: codes print to the terminal.
#
# Gmail (recommended):
#   1. Google Account → Security → enable 2-Step Verification
#   2. Security → App passwords → create one (e.g. "CareerCore")
#   3. Paste the 16-character password below with NO spaces
#   4. SMTP_USER = your real @gmail.com address; SMTP_FROM can match
#   5. Restart the backend after changing .env
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# LinkedIn OAuth (get credentials at https://www.linkedin.com/developers/apps)
# Create an app, add "Sign In with LinkedIn using OpenID Connect" product
# Set redirect URI to: http://localhost:8000/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
